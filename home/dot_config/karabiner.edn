;; ~/.config/karabiner.edn
;; Goku derleyicisi bu dosyayı ~/.config/karabiner/karabiner.json'a çevirir.
;;
;; Derleme: `goku` (tek seferlik)  |  `goku -w` (watch mode)
;; Karabiner-Elements otomatik olarak karabiner.json değişikliklerini izler.
;;
;; Modifier kısaltmaları: !C = cmd, !O = option, !S = shift, !T = control
;; Kombinasyonlar: !CS = cmd+shift, !CO = cmd+option, vb.
;;
;; Mimari:
;;   Caps Lock     tap=Esc / hold=NAV layer (text navigation)
;;   Right Command hold=WINDOW layer (calls aerospace CLI)
;;     - Right Command Karabiner Complex Modifications'da modifier flag
;;       olduğu için layer trigger olamıyor. Ansible karabiner.yml'da
;;       Simple Modifications üzerinden right_command → f19 remap'liyoruz
;;       (HID seviyesinde, complex'ten önce). Burada layer trigger f19.
;;   Spacebar      her zaman boşluk
;; Tek source-of-truth: bu dosya + Ansible jq-patch (RCmd→F19 simple mod).

{:profiles
 {:Default {:default true
            :sim     50
            :delay   500
            :alone   200
            :held    500}}

 ;; Layer tanımları
 :layers {:nav    {:key :caps_lock :alone {:key :escape}}
          :window {:key :f19}}

 :main
 [;; ──────────────────────────────────────────────────────────────────
  ;; NAV trigger workaround
  ;; Shift+Caps da NAV layer'ı tetiklesin (yoksa caps_lock OS'a düşüp
  ;; uppercase mode'u açar). Shift mandatory, OS hiç caps_lock görmez.
  ;; ──────────────────────────────────────────────────────────────────

  {:des "Shift+Caps → NAV layer trigger"
   :rules [[:!Scaps_lock
            [["nav" 1]]
            nil
            {:afterup [["nav" 0]]}]]}
  ;; NAV trigger workaround
  ;; Shift+Caps da NAV layer'ı tetiklesin (yoksa caps_lock OS'a düşüp
  ;; uppercase mode'u açar). Shift mandatory, OS hiç caps_lock görmez.
  ;; ──────────────────────────────────────────────────────────────────

  {:des "Shift+Caps → NAV layer trigger"
   :rules [[:!Scaps_lock
            [["nav" 1]]
            nil
            {:afterup [["nav" 0]]}]]}

  ;; ──────────────────────────────────────────────────────────────────
  ;; NAV layer (Caps hold) — Text navigation & selection
  ;; ──────────────────────────────────────────────────────────────────

  {:des "NAV layer — Caps hold"
   :rules [:nav
           ;; ── Hareket ──
           ;; Oklar (HJKL)
           [:h :left_arrow]
           [:j :down_arrow]
           [:k :up_arrow]
           [:l :right_arrow]
           ;; Kelime navigasyonu
           [:w [:!Oright_arrow]]    ;; word forward
           [:b [:!Oleft_arrow]]     ;; word backward
           ;; Satır navigasyonu
           [:a [:!Cleft_arrow]]     ;; line start
           [:e [:!Cright_arrow]]    ;; line end
           ;; Döküman navigasyonu
           [:u [:!Cup_arrow]]       ;; document start
           [:d [:!Cdown_arrow]]     ;; document end

           ;; ── Seçim (Shift + aynı tuş) ──
           ;; Karakter seçimi
           [:!Sh [:!Sleft_arrow]]
           [:!Sj [:!Sdown_arrow]]
           [:!Sk [:!Sup_arrow]]
           [:!Sl [:!Sright_arrow]]
           ;; Kelime seçimi
           [:!Sw [:!SOright_arrow]]
           [:!Sb [:!SOleft_arrow]]
           ;; Satır seçimi
           [:!Sa [:!CSleft_arrow]]
           [:!Se [:!CSright_arrow]]
           ;; Döküman seçimi
           [:!Su [:!CSup_arrow]]
           [:!Sd [:!CSdown_arrow]]]}

  ;; ──────────────────────────────────────────────────────────────────
  ;; WINDOW layer (Right Cmd hold) — AeroSpace CLI
  ;;
  ;; Tüm aksiyonlar `aerospace` CLI ile çalışır. AeroSpace TOML'ında
  ;; keybinding yok; tek source-of-truth burası.
  ;; ──────────────────────────────────────────────────────────────────

  {:des "WINDOW layer — Right Cmd hold (AeroSpace CLI)"
   :rules [:window
           ;; ── Focus (HJKL) ──
           [:h [{:shell_command "/opt/homebrew/bin/aerospace focus left"}]]
           [:j [{:shell_command "/opt/homebrew/bin/aerospace focus down"}]]
           [:k [{:shell_command "/opt/homebrew/bin/aerospace focus up"}]]
           [:l [{:shell_command "/opt/homebrew/bin/aerospace focus right"}]]

           ;; ── Move (Shift+HJKL) ──
           [:!Sh [{:shell_command "/opt/homebrew/bin/aerospace move left"}]]
           [:!Sj [{:shell_command "/opt/homebrew/bin/aerospace move down"}]]
           [:!Sk [{:shell_command "/opt/homebrew/bin/aerospace move up"}]]
           [:!Sl [{:shell_command "/opt/homebrew/bin/aerospace move right"}]]

           ;; ── Resize (Alt+HJKL) — H/L = width, J/K = height ──
           [:!Oh [{:shell_command "/opt/homebrew/bin/aerospace resize width -100"}]]
           [:!Ol [{:shell_command "/opt/homebrew/bin/aerospace resize width +100"}]]
           [:!Oj [{:shell_command "/opt/homebrew/bin/aerospace resize height +100"}]]
           [:!Ok [{:shell_command "/opt/homebrew/bin/aerospace resize height -100"}]]

           ;; ── Workspace switch (1-9, 0=10) ──
           [:1 [{:shell_command "/opt/homebrew/bin/aerospace workspace 1"}]]
           [:2 [{:shell_command "/opt/homebrew/bin/aerospace workspace 2"}]]
           [:3 [{:shell_command "/opt/homebrew/bin/aerospace workspace 3"}]]
           [:4 [{:shell_command "/opt/homebrew/bin/aerospace workspace 4"}]]
           [:5 [{:shell_command "/opt/homebrew/bin/aerospace workspace 5"}]]
           [:6 [{:shell_command "/opt/homebrew/bin/aerospace workspace 6"}]]
           [:7 [{:shell_command "/opt/homebrew/bin/aerospace workspace 7"}]]
           [:8 [{:shell_command "/opt/homebrew/bin/aerospace workspace 8"}]]
           [:9 [{:shell_command "/opt/homebrew/bin/aerospace workspace 9"}]]
           [:0 [{:shell_command "/opt/homebrew/bin/aerospace workspace 10"}]]

           ;; ── Move window to workspace (Shift+1-9, Shift+0=10) ──
           [:!S1 [{:shell_command "/opt/homebrew/bin/aerospace move-node-to-workspace 1"}]]
           [:!S2 [{:shell_command "/opt/homebrew/bin/aerospace move-node-to-workspace 2"}]]
           [:!S3 [{:shell_command "/opt/homebrew/bin/aerospace move-node-to-workspace 3"}]]
           [:!S4 [{:shell_command "/opt/homebrew/bin/aerospace move-node-to-workspace 4"}]]
           [:!S5 [{:shell_command "/opt/homebrew/bin/aerospace move-node-to-workspace 5"}]]
           [:!S6 [{:shell_command "/opt/homebrew/bin/aerospace move-node-to-workspace 6"}]]
           [:!S7 [{:shell_command "/opt/homebrew/bin/aerospace move-node-to-workspace 7"}]]
           [:!S8 [{:shell_command "/opt/homebrew/bin/aerospace move-node-to-workspace 8"}]]
           [:!S9 [{:shell_command "/opt/homebrew/bin/aerospace move-node-to-workspace 9"}]]
           [:!S0 [{:shell_command "/opt/homebrew/bin/aerospace move-node-to-workspace 10"}]]

           ;; ── Layout / Window ──
           [:f     [{:shell_command "/opt/homebrew/bin/aerospace fullscreen"}]]
           [:!Sf   [{:shell_command "/opt/homebrew/bin/aerospace layout floating tiling"}]]  ;; toggle floating
           [:s     [{:shell_command "/opt/homebrew/bin/aerospace layout tiles horizontal vertical"}]]  ;; toggle split
           [:q     [{:shell_command "/opt/homebrew/bin/aerospace close"}]]

           ;; ── Misc ──
           [:tab   [{:shell_command "/opt/homebrew/bin/aerospace workspace-back-and-forth"}]]
           [:r     [{:shell_command "/opt/homebrew/bin/aerospace reload-config"}]]]}]}
