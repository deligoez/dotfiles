;; Kanata config — HJKL-first keybindings
;; https://github.com/jtroo/kanata/blob/main/docs/config.adoc

(defcfg
  process-unmapped-keys yes
  concurrent-tap-hold yes
)

(defsrc
  caps  h     j     k     l
)

(defalias
  ;; Caps Lock: tap = Esc, hold = NAV layer
  nav  (tap-hold 200 200 esc (layer-while-held nav))
)

(deflayer base
  @nav  h     j     k     l
)

(deflayer nav
  _     left  down  up    right
)
